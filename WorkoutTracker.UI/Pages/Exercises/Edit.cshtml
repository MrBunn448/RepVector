@page "{id:int}"
@model WorkoutTracker.UI.Pages.Exercises.EditModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/Exercises">Exercises</a></li>
                    <li class="breadcrumb-item active">Edit</li>
                </ol>
            </nav>

            <div class="card shadow-sm border-0">
                <div class="card-header @(Model.IsAdmin ? "bg-warning text-dark" : "bg-primary text-white") py-3">
                    <h4 class="mb-0 fw-bold">
                        <i class="bi bi-pencil-square me-2"></i>
                        Edit Exercise
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <input type="hidden" asp-for="Exercise.Id">
                        <input type="hidden" asp-for="Exercise.UserId">
                        <input type="hidden" asp-for="Exercise.CreatedAt">

                        <div class="row mb-4">
                            <div class="col-md-12 mb-3">
                                <label for="Exercise_Name" class="form-label fw-bold">Exercise Name</label>
                                <input type="text" class="form-control form-control-lg" id="Exercise_Name" asp-for="Exercise.Name" 
                                       placeholder="e.g., Incline Bench Press" required>
                                <span asp-validation-for="Exercise.Name" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="Exercise_Type" class="form-label fw-bold">Equipment Type</label>
                                <select class="form-select" id="Exercise_Type" asp-for="Exercise.Type" asp-items="Model.ExerciseTypes">
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="Exercise_Muscle" class="form-label fw-bold">Primary Muscle Group</label>
                                <select class="form-select" id="Exercise_Muscle" asp-for="Exercise.PrimaryMuscleGroupId" asp-items="Model.MuscleGroups">
                                    <option value="">-- Uncategorized --</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="Exercise_Description" class="form-label fw-bold">Instructions & Form Tips</label>
                            <textarea class="form-control" id="Exercise_Description" asp-for="Exercise.Description" 
                                      placeholder="Explain how to perform the movement safely..." rows="4"></textarea>
                        </div>

                        @if (Model.IsAdmin)
                        {
                            <div class="form-check form-switch p-3 bg-light rounded border border-warning mb-4">
                                <input class="form-check-input ms-0 me-2" type="checkbox" id="isPredefined" asp-for="Exercise.IsPredefined">
                                <label class="form-check-label fw-bold text-dark" for="isPredefined">
                                    Global Library Movement
                                </label>
                                <div class="form-text">If checked, this remains an official RepVector exercise.</div>
                            </div>
                        }

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg px-5 fw-bold">
                                Save Changes
                            </button>
                            <a href="/Exercises" class="btn btn-outline-secondary btn-lg px-4">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
