@page
@model LoginModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2>Login</h2>
            <!-- Triggers on wrong password. (Model error) Currently outputs Full error message, change to user friendly error-->
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form method="post">
                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <input type="email" class="form-control" id="email" asp-for="Email" required />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" id="password" asp-for="Password" required />
                </div>

                <button type="submit" class="btn btn-primary">Login</button>
                <a href="/auth/register" class="btn btn-link">Don't have an account? Register</a>
            </form>
        </div>
    </div>
</div>
