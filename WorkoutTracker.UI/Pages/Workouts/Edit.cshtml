@page "{id:int}"
@model WorkoutTracker.UI.Pages.Workouts.EditModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/Workouts">Workouts</a></li>
                    <li class="breadcrumb-item active">Edit</li>
                </ol>
            </nav>

            <div class="card shadow-sm border-0">
                <div class="card-header @(Model.IsAdmin ? "bg-warning text-dark" : "bg-primary text-white") py-3">
                    <h4 class="mb-0 fw-bold">
                        <i class="bi bi-pencil-square me-2"></i>
                        @(Model.IsAdmin ? "Edit Global Template" : "Edit My Workout")
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <input type="hidden" asp-for="Workout.Id">
                        <input type="hidden" asp-for="Workout.UserId">
                        <input type="hidden" asp-for="Workout.CreatedAt">

                        <div class="mb-4">
                            <label for="Workout_Name" class="form-label fw-bold">Workout Name</label>
                            <input type="text" class="form-control form-control-lg" id="Workout_Name" asp-for="Workout.Name" 
                                   placeholder="e.g., Heavy Push Day" required>
                            <span asp-validation-for="Workout.Name" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label for="Workout_Description" class="form-label fw-bold">Description (Optional)</label>
                            <textarea class="form-control" id="Workout_Description" asp-for="Workout.Description" 
                                      placeholder="What is this routine for?" rows="3"></textarea>
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="fw-bold mb-0">Exercises</h5>
                                <button type="button" class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#addExerciseModal">
                                    <i class="bi bi-plus-circle me-1"></i> Add Exercise
                                </button>
                            </div>

                            <div id="exerciseList">
                                @for (int i = 0; i < Model.Workout.Exercises.Count; i++)
                                {
                                    <div class="card mb-3 exercise-item border shadow-sm">
                                        <div class="card-body py-2 px-3">
                                            <div class="row align-items-center">
                                                <div class="col">
                                                    <input type="hidden" name="Workout.Exercises[@i].ExerciseId" value="@Model.Workout.Exercises[i].ExerciseId">
                                                    <input type="hidden" name="Workout.Exercises[@i].Id" value="@Model.Workout.Exercises[i].Id">
                                                    <input type="hidden" name="Workout.Exercises[@i].WorkoutId" value="@Model.Workout.Exercises[i].WorkoutId">
                                                    <input type="hidden" name="Workout.Exercises[@i].SortOrder" value="@i" class="sort-order">
                                                    
                                                    <div class="fw-bold text-primary">@Model.Workout.Exercises[i].Exercise?.Name</div>
                                                </div>
                                                <div class="col-auto">
                                                    <div class="input-group input-group-sm" style="width: 130px;">
                                                        <span class="input-group-text">Sets</span>
                                                        <input type="number" name="Workout.Exercises[@i].TargetSets" class="form-control" value="@Model.Workout.Exercises[i].TargetSets" min="1">
                                                    </div>
                                                </div>
                                                <div class="col-auto">
                                                    <div class="input-group input-group-sm" style="width: 130px;">
                                                        <span class="input-group-text">Reps</span>
                                                        <input type="number" name="Workout.Exercises[@i].TargetReps" class="form-control" value="@Model.Workout.Exercises[i].TargetReps" min="1">
                                                    </div>
                                                </div>
                                                <div class="col-auto">
                                                    <button type="button" class="btn btn-sm btn-outline-danger border-0 remove-exercise">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        @if (Model.IsAdmin)
                        {
                            <div class="form-check form-switch p-3 bg-light rounded border border-warning mb-4">
                                <input class="form-check-input ms-0 me-2" type="checkbox" id="isPredefined" asp-for="Workout.IsPredefined">
                                <label class="form-check-label fw-bold text-dark" for="isPredefined">
                                    Global Public Template
                                </label>
                                <div class="form-text">Visible to all users for their training.</div>
                            </div>
                        }

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg px-5 fw-bold">
                                Save Changes
                            </button>
                            <a href="/Workouts/Details/@Model.Workout.Id" class="btn btn-outline-secondary btn-lg px-4">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Exercise Modal -->
<div class="modal fade" id="addExerciseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title fw-bold">Add Exercise to Workout</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                    @foreach (var ex in Model.AllExercises.OrderBy(e => e.Name))
                    {
                        <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3" 
                                onclick="addExercise('@ex.Id', '@ex.Name')">
                            <div>
                                <div class="fw-bold">@ex.Name</div>
                                <div class="small text-muted">@ex.Type • @(ex.PrimaryMuscleGroup?.Name ?? "Other")</div>
                            </div>
                            <i class="bi bi-plus-circle-fill text-success fs-4"></i>
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function addExercise(id, name) {
            const list = document.getElementById('exerciseList');
            const index = list.querySelectorAll('.exercise-item').length;
            
            const html = `
                <div class="card mb-3 exercise-item border shadow-sm">
                    <div class="card-body py-2 px-3">
                        <div class="row align-items-center">
                            <div class="col">
                                <input type="hidden" name="Workout.Exercises[${index}].ExerciseId" value="${id}">
                                <input type="hidden" name="Workout.Exercises[${index}].SortOrder" value="${index}" class="sort-order">
                                <div class="fw-bold text-primary">${name}</div>
                            </div>
                            <div class="col-auto">
                                <div class="input-group input-group-sm" style="width: 130px;">
                                    <span class="input-group-text">Sets</span>
                                    <input type="number" name="Workout.Exercises[${index}].TargetSets" class="form-control" value="3" min="1">
                                </div>
                            </div>
                            <div class="col-auto">
                                <div class="input-group input-group-sm" style="width: 130px;">
                                    <span class="input-group-text">Reps</span>
                                    <input type="number" name="Workout.Exercises[${index}].TargetReps" class="form-control" value="10" min="1">
                                </div>
                            </div>
                            <div class="col-auto">
                                <button type="button" class="btn btn-sm btn-outline-danger border-0 remove-exercise">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            
            const div = document.createElement('div');
            div.innerHTML = html;
            list.appendChild(div.firstElementChild);
            
            bootstrap.Modal.getInstance(document.getElementById('addExerciseModal')).hide();
        }

        document.getElementById('exerciseList').addEventListener('click', function(e) {
            if (e.target.closest('.remove-exercise')) {
                e.target.closest('.exercise-item').remove();
                reindexExercises();
            }
        });

        function reindexExercises() {
            const items = document.querySelectorAll('.exercise-item');
            items.forEach((item, index) => {
                item.querySelectorAll('input').forEach(input => {
                    const name = input.getAttribute('name');
                    if (name) {
                        input.setAttribute('name', name.replace(/\[\d+\]/, `[${index}]`));
                    }
                });
                const sortInput = item.querySelector('.sort-order');
                if (sortInput) sortInput.value = index;
            });
        }
    </script>
}
