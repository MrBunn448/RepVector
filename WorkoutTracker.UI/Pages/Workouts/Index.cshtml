@page
@model WorkoutTracker.UI.Pages.Workouts.IndexModel

@{
    bool isAdmin = HttpContext.Session.GetString("UserRole") == "Admin";
}

<div class="container mt-5">
    @if (!string.IsNullOrEmpty(Model.ConflictError))
    {
        <div class="alert alert-warning shadow-sm border-warning d-flex align-items-center mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
            <div class="flex-grow-1">
                <h5 class="alert-heading fw-bold mb-1">Ongoing Workout Detected</h5>
                <p class="mb-0">You already have an active workout session. Starting a new one will cancel the current session.</p>
            </div>
            <div class="ms-3 d-flex gap-2">
                <form method="post" asp-page-handler="StartSession" asp-route-id="@Model.ConflictingWorkoutId" asp-route-force="true">
                    <button type="submit" class="btn btn-warning fw-bold">Cancel Old & Start New</button>
                </form>
                <a href="/Workouts/Active" class="btn btn-outline-dark">Resume Active</a>
            </div>
        </div>
    }

    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h1 class="display-4 fw-bold">Workout Hub</h1>
            <p class="lead text-muted">Manage your personal routine or explore global templates.</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="/Workouts/Create" class="btn btn-primary btn-lg shadow-sm">
                <i class="bi bi-plus-circle me-2"></i>
                @(isAdmin ? "Create Workout Template" : "Create New Workout")
            </a>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <ul class="nav nav-pills mb-4" id="workoutTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold" id="personal-tab" data-bs-toggle="pill" data-bs-target="#personal" type="button" role="tab">
                My Workouts <span class="badge bg-secondary ms-1">@Model.PersonalWorkouts.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold" id="templates-tab" data-bs-toggle="pill" data-bs-target="#templates" type="button" role="tab">
                Workout Templates <span class="badge bg-danger ms-1">@Model.WorkoutTemplates.Count</span>
            </button>
        </li>
    </ul>

    <div class="tab-content" id="workoutTabsContent">
        <!-- Personal Workouts Tab -->
        <div class="tab-pane fade show active" id="personal" role="tabpanel">
            @if (Model.PersonalWorkouts.Count == 0)
            {
                <div class="text-center py-5 bg-light rounded border border-dashed">
                    <h3 class="text-muted">No personal workouts yet</h3>
                    <p>Start by creating your own custom routine.</p>
                    <a href="/Workouts/Create" class="btn btn-outline-primary mt-2">Create First Workout</a>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var workout in Model.PersonalWorkouts)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0">
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title fw-bold">@workout.Name</h5>
                                    <p class="card-text text-muted small">Created: @workout.CreatedAt.ToString("MMM dd, yyyy")</p>
                                    
                                    <div class="mt-auto">
                                        <form method="post" asp-page-handler="StartSession" asp-route-id="@workout.Id" class="mb-2">
                                            <button type="submit" class="btn btn-success w-100 shadow-sm">
                                                <i class="bi bi-play-fill me-1"></i> Start Workout
                                            </button>
                                        </form>
                                        <div class="d-flex gap-2">
                                            <a href="/Workouts/Details/@workout.Id" class="btn btn-sm btn-outline-info flex-grow-1">View</a>
                                            <a href="/Workouts/Edit/@workout.Id" class="btn btn-sm btn-outline-warning flex-grow-1">Edit</a>
                                            <a href="/Workouts/Delete/@workout.Id" class="btn btn-sm btn-outline-danger flex-grow-1" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Workout Templates Tab -->
        <div class="tab-pane fade" id="templates" role="tabpanel">
            @if (Model.WorkoutTemplates.Count == 0)
            {
                <div class="text-center py-5 bg-light rounded">
                    <h3 class="text-muted">No global templates available</h3>
                    <p>Check back later for curated workout plans.</p>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var workout in Model.WorkoutTemplates)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0 border-top border-danger border-3">
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title fw-bold">@workout.Name</h5>
                                        <span class="badge bg-danger">Template</span>
                                    </div>
                                    <p class="card-text text-muted small">Global Routine</p>
                                    
                                    <div class="mt-auto">
                                        <form method="post" asp-page-handler="StartSession" asp-route-id="@workout.Id" class="mb-2">
                                            <button type="submit" class="btn btn-success w-100 shadow-sm">
                                                <i class="bi bi-play-fill me-1"></i> Start Template
                                            </button>
                                        </form>
                                        <div class="d-flex gap-2">
                                            <a href="/Workouts/Details/@workout.Id" class="btn btn-sm btn-outline-info flex-grow-1">Details</a>
                                            @if (isAdmin)
                                            {
                                                <a href="/Workouts/Edit/@workout.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                                                <a href="/Workouts/Delete/@workout.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .nav-pills .nav-link.active {
        background-color: #0d6efd;
    }
    .nav-pills .nav-link {
        color: #6c757d;
        border-radius: 0.5rem;
    }
    .card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
    .border-dashed {
        border: 2px dashed #dee2e6!important;
    }
</style>
